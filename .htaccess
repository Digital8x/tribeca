# ══════════════════════════════════════════════════════════════
#  Tribeca The Everett — PM2 Reverse Proxy .htaccess
# ══════════════════════════════════════════════════════════════

Options -Indexes
DirectoryIndex index.html
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Proxy traffic to PM2 Node.js server running on internal port 3008
# IMPORTANT: If your PM2 app is running on a different port, change 3008 below.
RewriteRule ^(.*)$ http://127.0.0.1:3008/$1 [P,L]

# ── Hotlink Protection for images ─────────────────────────────
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^https?://(www\.)?tribecatheeverett\.com [NC]
RewriteCond %{HTTP_REFERER} !^https?://(www\.)?localhost [NC]
RewriteRule \.(jpg|jpeg|png|gif|webp|svg)$ - [F,NC]

# ── Security Headers ──────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ── Block access to sensitive files ───────────────────────────
<FilesMatch "\.(json|env|log|sh|sql|md|git)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# Block direct access to the data directory
<IfModule mod_rewrite.c>
  RewriteRule ^data/ - [F,L]
</IfModule>

# ── Compression (performance) ─────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json
</IfModule>

# ── Browser Caching ───────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png  "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType text/css   "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
</IfModule>
